# Public API (optional — production has a safe default)
NEXT_PUBLIC_API_URL=https://sentinel-ledger-backend-production.up.railway.app
NEXT_PUBLIC_WS_URL=wss://sentinel-ledger-backend-production.up.railway.app

# Optional: dedicated Solana RPC for the browser (no Helius secret here; use a public or paid RPC URL you control)
NEXT_PUBLIC_SOLANA_RPC_URL=

# WalletConnect Cloud project ID → enables mobile / Binance-style flows in the wallet modal
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Canonical site URL for WalletConnect metadata (defaults to Vercel prod if unset)
NEXT_PUBLIC_SITE_URL=https://sentinel-ledger-ochre.vercel.app

# Stripe success/cancel redirects (optional; backend also uses SENTINEL_APP_URL)
NEXT_PUBLIC_APP_URL=https://sentinel-ledger-ochre.vercel.app

# Telegram Login Widget — Bot username (no @) for /alerts PRO linking. Set the same domain in @BotFather /setdomain.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
