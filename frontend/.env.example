# Public API (optional — production has a safe default)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# Optional: dedicated Solana RPC for the browser (no Helius secret here; use a public or paid RPC URL you control)
NEXT_PUBLIC_SOLANA_RPC_URL=

# WalletConnect Cloud project ID → enables mobile / Binance-style flows in the wallet modal
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Canonical site URL for WalletConnect metadata (defaults to Vercel prod if unset)
NEXT_PUBLIC_SITE_URL=https://sentinel-ledger-ochre.vercel.app

# Optional: surface donation wallet on /pricing
NEXT_PUBLIC_DONATION_WALLET=
