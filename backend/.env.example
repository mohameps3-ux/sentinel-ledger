PORT=3000
NODE_ENV=production
JWT_SECRET=change_me_now_use_a_long_random_string
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Direct Postgres URI (Supabase → Project Settings → Database → URI, session or transaction mode). Required for `npm run db:ensure-subscriptions` (applies `../supabase/payments_and_pro.sql`).
# Also used by `npm run db:ensure-signal-performance` (loads backend/.env regardless of cwd).
# If lines are empty locally, with backend/ linked to Railway:
#   • `railway run npm run db:sync-database-url-from-railway` (env injected), or
#   • From monorepo root: `npm run db:sync-database-url-from-railway --prefix backend`
#     (CLI runs with cwd=backend/ so `railway variable list --json` resolves the link; no `railway run`)
# DATABASE_URL=
# SUPABASE_DATABASE_URL=
# --- DB migrations (script only; API at runtime uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY) ---
# Set DATABASE_URL or SUPABASE_DATABASE_URL above, then once: `node backend/scripts/applySignalPerformanceSchema.js` (or `npm run db:ensure-signal-performance` from backend/).
# Applies: 003_signal_performance, 011_signal_performance_emission_regime, 010_wallet_coordination_alerting, 012_coordination_outcomes.
# Optional: COORD_OUTCOME_* in this file. If 012 is not applied, the app does not hard-fail; verified recurrence falls back to signal_performance when there is no coordination_outcomes row (missing table → empty join → same fallback).
# Optional: Upstash Redis REST (free tier). If unset, terminal API cache falls back to in-memory (still $0).
UPSTASH_REDIS_REST_URL=your_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token
# Home terminal endpoints cache TTL (seconds), default 180.
HOME_TERMINAL_CACHE_TTL_SEC=180
# Hot endpoint cache TTL (seconds). Recommended: 60-120.
HOME_TERMINAL_HOT_CACHE_TTL_SEC=90
# Latest signals endpoint cache TTL (seconds). Recommended: 60-120.
HOME_TERMINAL_LATEST_CACHE_TTL_SEC=90
# Cap for GET /api/v1/signals/latest and buildLatestSignalsFeed (default 64; keep ≥ war home GRID_EXPANDED 56; lower to reduce getMarketData work per request).
# SIGNAL_FEED_MAX_CARDS=64
# SLO target for signals/latest source=supabase rate (0..1) in /ops/data-freshness.
SIGNALS_LATEST_SUPABASE_SLO_TARGET=0.8
# Alert when supabaseSourceRate24h stays under target for sustained time.
SIGNALS_SUPABASE_SLO_ALERT_ENABLED=true
SIGNALS_SUPABASE_SLO_ALERT_AFTER_MINUTES=20
SIGNALS_SUPABASE_SLO_ALERT_MIN_REQUESTS_24H=25
SIGNALS_SUPABASE_SLO_ALERT_COOLDOWN_MS=300000
# In-process SLO evaluation loop interval (ms).
SIGNALS_SUPABASE_SLO_EVAL_MS=30000
# Persist data-freshness snapshots to Supabase for historical analysis.
FRESHNESS_HISTORY_CRON_ENABLED=true
FRESHNESS_HISTORY_TICK_MS=300000
FRESHNESS_HISTORY_RETENTION_DAYS=30
# Alert on historical trend degradation (signalsLatest): sustained low rate + negative slope.
FRESHNESS_HISTORY_ALERT_ENABLED=true
FRESHNESS_HISTORY_ALERT_LOOKBACK_HOURS=24
FRESHNESS_HISTORY_ALERT_MIN_POINTS=6
FRESHNESS_HISTORY_ALERT_SUSTAIN_POINTS=4
FRESHNESS_HISTORY_ALERT_NEGATIVE_SLOPE_PER_HOUR=-0.005
FRESHNESS_HISTORY_ALERT_RATE_GAP=0.02
FRESHNESS_HISTORY_ALERT_MIN_REQUESTS_24H=30
FRESHNESS_HISTORY_ALERT_COOLDOWN_MS=300000
# Signing key for integrity-protected historical export
# (/api/v1/ops/data-freshness/history/export/signed).
# If unset, it falls back to OMNI_BOT_OPS_KEY.
FRESHNESS_HISTORY_EXPORT_SIGNING_KEY=
# Optional Ed25519 seed (32 bytes, base64). When set, signed exports use Ed25519 (offline verifiable with public key).
# Public key: GET /api/v1/public/freshness-export-verification-key — or set explicitly:
FRESHNESS_HISTORY_EXPORT_ED25519_SEED_BASE64=
FRESHNESS_HISTORY_EXPORT_ED25519_PUBLIC_BASE64=
# Public POST /api/v1/ops/verify-signed-export (no auth, rate-limited). Third parties send the full signed JSON; response is PASS/FAIL only.
FRESHNESS_HISTORY_VERIFY_ENABLED=true
FRESHNESS_HISTORY_VERIFY_WINDOW_MS=900000
FRESHNESS_HISTORY_VERIFY_MAX_PER_WINDOW=30
FRESHNESS_HISTORY_VERIFY_MAX_ROWS=6000
# Optional: only needed if you want BullMQ queues locally.
UPSTASH_REDIS_URL=redis://default:password@host:port
# Optional alias for BullMQ connection string (if you prefer REDIS_URL naming).
REDIS_URL=
# Optional: set to "false" to pause deployer/smart-wallet workers without code changes.
SMART_WORKERS_ENABLED=true
# Optional: when BullMQ is unavailable (no REDIS_URL), analyze up to N wallets directly per cron run.
SMART_WALLET_DIRECT_LIMIT=20
HELIUS_KEY=your_helius_api_key
# Optional: comma-separated Solana JSON-RPC HTTPS URLs tried before Helius and public mainnet (reduces 429 on Helius).
# Example: https://xxx.solana-mainnet.quiknode.pro/your_key/
SOLANA_RPC_URL=
SOLANA_RPC_URLS=
# Optional: Birdeye Data Services — realized PnL per wallet for a given token (GET /wallet/v2/pnl/multiple).
# https://bds.birdeye.so — Lite+ plans include Wallet PnL APIs.
BIRDEYE_API_KEY=
# Set to "true" only to fall back to curated smart_wallets rows in Supabase (demo).
# Default: on-chain only (Helius + RPC).
SMART_MONEY_DB_FALLBACK=false

# Enrich smart_wallet_signals with DexScreener spot USD
# (entry → 5m → 30m → 1h → 2h → 4h by row age). No BullMQ required.
# (Typo in some docs: use SIGNAL_PRICE_CRON_ENABLED, not SIGNAL_PRICE_CROWN_ENABLED.)
SIGNAL_PRICE_CRON_ENABLED=true
# Optional: tick interval (ms), min 60000.
SIGNAL_PRICE_TICK_MS=300000
# Max rows per category (missing entry / due 5m / 30m / 1h / 2h / 4h) each tick.
SIGNAL_PRICE_BATCH=30
# Pause between DexScreener calls for distinct mints (ms).
SIGNAL_PRICE_DEX_DELAY_MS=200

# GET /api/v1/portfolio/watchlist-markets — pause between DexScreener calls (ms).
PORTFOLIO_DEX_DELAY_MS=120
# Max watchlist rows enriched per request (1–40).
PORTFOLIO_MAX_TOKENS=24

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# PRO watchlist alerts (Telegram). Set false to disable periodic checks.
PRO_ALERTS_CRON_ENABLED=true
# Optional: how often to scan watchlists (ms), min 60000.
PRO_ALERTS_TICK_MS=600000
# Optional: cache TTL (seconds) for smart-money summary merged into PRO Telegram alerts.
PRO_ALERT_SMART_HINT_TTL_SEC=900
# Optional: min top confidence (0–100) to mention smart money when wallet count is low.
PRO_ALERT_SMART_HINT_MIN_CONF=38
# Comma-separated Solana addresses to skip in wallet analysis worker (vaults, infra).
SMART_WALLET_SKIP_ANALYSIS=
# Dedupe window for live inserts into smart_wallet_signals (seconds).
SMART_WALLET_SIGNAL_DEDUP_SEC=120
# Backfill smart_wallet_signals from recent wallet_tokens (safe, rate-limited).
SMART_SIGNAL_BACKFILL_ENABLED=true
SMART_SIGNAL_BACKFILL_TICK_MS=180000
SMART_SIGNAL_BACKFILL_BATCH=40
SMART_SIGNAL_BACKFILL_LOOKBACK_HOURS=24
SMART_SIGNAL_BACKFILL_DEDUPE_MINUTES=120
SMART_SIGNAL_BACKFILL_MIN_WIN_RATE=70

# Wallet behavior memory (F5): persistent wallet intelligence refresh.
WALLET_BEHAVIOR_CRON_ENABLED=true
WALLET_BEHAVIOR_TICK_MS=21600000
WALLET_BEHAVIOR_LOOKBACK_DAYS=30
WALLET_BEHAVIOR_MAX_WALLETS=200
WALLET_BEHAVIOR_MIN_SAMPLE_FOR_STYLE=5

# Historical coordination engine (F6): recurring wallet clusters + red alerts.
WALLET_COORD_CRON_ENABLED=true
WALLET_COORD_CRON_TICK_MS=21600000
WALLET_COORD_LOOKBACK_DAYS=30
WALLET_COORD_MAX_WALLETS=400
WALLET_COORD_WINDOW_MIN=10
COORD_PAIR_CACHE_TTL_SEC=300
COORD_ALERT_DEDUPE_SEC=900
COORD_EARLY_DEPLOY_MAX_MIN=120
COORD_MIN_PAIR_COBUY=3
COORD_MIN_PAIR_STRENGTH=0.55
COORD_ALERT_MIN_CLUSTER_SCORE=0.68
COORD_ALERT_MIN_WALLETS=3
# Fase B: ORANGE band (RED_PREPARE) before RED_CONFIRM; Redis + socket RED_ABORT when cluster breaks.
COORD_RED_PREPARE_ENABLED=true
COORD_RED_PREPARE_MIN_SCORE=0.55
COORD_PREPARE_TTL_SEC=600
COORD_PREPARE_EMIT_DEDUPE_SEC=90
# Recurrence stats: join prior alerts to signal_performance (resolved, emitted after that alert) as “verified pump” proxy.
COORD_RECURRENCE_VERIFIED_PUMPS=true
# Min resolved outcome_pct (defaults to SIGNAL_PERF_SUCCESS_MIN_PCT, usually 1.0).
# COORD_RECURRENCE_PUMP_MIN_OUTCOME_PCT=1
# Prefer T+N market resolution (coordination_outcomes) over signal_performance; legacy = no row only.
COORD_RECURRENCE_PREFER_MARKET_OUTCOMES=true
# When an alert has no coordination_outcome row (pre-migration), fall back to signal_performance match.
COORD_RECURRENCE_SIGNAL_PERF_FALLBACK=true
# T+N market outcome for each coordination alert (same getMarketData path as signal_performance).
COORD_OUTCOME_ENABLED=true
COORD_OUTCOME_CRON_ENABLED=true
COORD_OUTCOME_TICK_MS=60000
COORD_OUTCOME_HORIZON_MIN=30
# Optional: resolution batch and retry cap (same spirit as SIGNAL_PERF_*).
# COORD_OUTCOME_RESOLVE_BATCH=50
# COORD_OUTCOME_MAX_ATTEMPTS=12
# Min return% at T+N to count as “verified pump” in coordination_outcomes (and primary recurrence filter).
# COORD_OUTCOME_PUMP_MIN_PCT=1
# Optional: enable Telegram command polling (/scan, /watchlist). Keep false in production workers to avoid 409 conflicts.
TELEGRAM_POLLING_ENABLED=false
OMNI_BOT_OPS_KEY=set_a_long_random_ops_key
# Deployed API origin for local ops scripts (e.g. npm run ops:signal-gate-tuner-dry-run).
# Precedence: OPS_DRY_RUN_BACKEND_URL → RAILWAY_PUBLIC_DOMAIN (when using `railway run …`) → BACKEND_URL.
# BACKEND_URL=https://your-service.up.railway.app
# Tuner: GET /api/v1/ops/signal-gate/tuner/preview is read-only (no threshold writes). The ops:signal-gate-tuner-dry-run
# script uses preview by default; set OPS_TUNER_DRY_USE_POST=1 (or --post) to also POST /tuner/run.
# Optional Entropy Guard Ops alerts (Step 2).
# Trigger when drops/window exceed threshold for N windows OR memory crosses ratio.
RULE_ENTROPY_ALERT_DROPS_PER_WINDOW=5000
RULE_ENTROPY_ALERT_SUSTAIN_WINDOWS=3
RULE_ENTROPY_HISTORY_POINTS=60
RULE_ENTROPY_MEMORY_LIMIT_BYTES=8388608
RULE_ENTROPY_MEMORY_PRESSURE_RATIO=0.8
# Cooldown between critical webhook notifications while pressure is ongoing (ms).
RULE_ENTROPY_ALERT_WEBHOOK_COOLDOWN_MS=300000
# Optional: Discord/Slack webhook URL for critical Ops alerts.
OPS_ALERT_WEBHOOK_URL=
# Daily Ops heartbeat to verify webhook health before incidents.
OPS_HEARTBEAT_ENABLED=true
# Heartbeat interval in ms (min 1h). Default 24h.
OPS_HEARTBEAT_TICK_MS=86400000
# Append signal_performance summary to heartbeat webhook (needs Supabase + table).
OPS_HEARTBEAT_SIGNAL_PERF=true
OPS_HEARTBEAT_SIGNAL_PERF_LOOKBACK_H=48
# Alert if /signals/latest stays in static_fallback for longer than X minutes.
SIGNALS_LATEST_STATIC_ALERT_AFTER_MINUTES=10
# Cooldown between repeated sustained static_fallback alerts.
SIGNALS_LATEST_STATIC_ALERT_COOLDOWN_MS=300000

# Signal performance feedback loop (0€ mode): archive -> resolve outcomes -> metrics.
# After pulling regime-gate persistence, apply DB migration 011 (see npm script db:ensure-signal-performance).
SIGNAL_PERF_CRON_ENABLED=true
SIGNAL_PERF_TICK_MS=60000
SIGNAL_PERF_HORIZON_MIN=10
SIGNAL_PERF_RESOLVE_BATCH=60
SIGNAL_PERF_MAX_ATTEMPTS=12
# Success threshold for win-rate/profit-factor calculations.
SIGNAL_PERF_SUCCESS_MIN_PCT=1.0
# Volume note: rows start pending; they become resolved after T+N (resolve_after), where N is
# horizon_min (default SIGNAL_PERF_HORIZON_MIN). The resolution job must run (SIGNAL_PERF_CRON_*).
# Global metrics and regimes[] in getSignalPerformanceSummary only count resolved rows in the
# lookback. Few resolved -> tuner stays insufficient_resolved_sample or regime branches are thin — expected.
# Signal emission gate (Phase A): unified score + strict pre-emit checks.
SIGNAL_GATE_ENABLED=true
SIGNAL_GATE_MIN_CONFIDENCE=55
SIGNAL_GATE_MIN_UNIFIED_SCORE=0.58
SIGNAL_GATE_MIN_LIQUIDITY_USD=20000
SIGNAL_GATE_MAX_RISK_SCORE=85
SIGNAL_GATE_MIN_SIGNALS_FIRED=1
SIGNAL_GATE_HISTORY_MAX=300
# Fase A.1/A.2 — Alpha layer (evProxy, slippage risk, meta-label) on each score.meta.alphaLayer. Always on unless:
#   SIGNAL_ALPHA_LAYER_ENABLED=false
SIGNAL_ALPHA_LAYER_ENABLED=true
# Shrink 0.85–0.99 to bias gate toward under-confidence (calibratedConfidence).
SIGNAL_CONFIDENCE_CALIBRATION=1.0
# Heuristic "late cluster" (many events + velocity vs baseline).
# SIGNAL_ALPHA_LATE_MIN_WALLETS=4
# SIGNAL_ALPHA_LATE_MIN_EVENTS=8
# SIGNAL_ALPHA_LATE_TX_TO_BASELINE_MULT=3
# Stricter gating (default off = observe only, no new blocks). Set min EV 0.12+ or max slip 0.6 when ready.
SIGNAL_GATE_USE_CALIBRATED_CONFIDENCE=false
# Min expected-value proxy 0..1 (0 = disabled)
SIGNAL_GATE_MIN_EV_PROXY=0
# Max slippage risk 0..1 (1 = disabled)
SIGNAL_GATE_MAX_SLIPPAGE_RISK=1
SIGNAL_GATE_META_BLOCK_SKIP=false
SIGNAL_GATE_META_BLOCK_CAUTION=false
# Cheap market regime for gate thresholds (uses existing Dex/Birdeye fields only: 24h % change, volume, liquidity).
# Default off — no behavior change until SIGNAL_GATE_REGIME_ENABLED=true.
SIGNAL_GATE_REGIME_ENABLED=false
# Classifier: abs(24h % change) and volume/liquidity ratio (Dex-style turnover vs pool depth).
SIGNAL_GATE_REGIME_VOLATILE_ABS_PCT=12
SIGNAL_GATE_REGIME_TRENDING_ABS_PCT=5
SIGNAL_GATE_REGIME_VOLATILE_VOL_LIQ_RATIO=10
# Optional per-regime overrides (only when regime enabled). Examples:
# SIGNAL_GATE_REGIME_VOLATILE_MIN_CONFIDENCE=65
# SIGNAL_GATE_REGIME_TRENDING_MIN_UNIFIED_SCORE=0.62
# SIGNAL_GATE_REGIME_CALM_MAX_RISK_SCORE=88
# Adaptive tuner (no extra cost): reads existing signal_performance and
# suggests/applies bounded gate updates. Keep disabled until enough sample.
#
# To actually apply suggestions (not only run/dry-run): set
#   SIGNAL_GATE_ADAPTIVE_ENABLED=true
# and watch Ops / `lastApplied` / gate reason strings after deploy.
# Optional, when you want worst-bucket (emission_regime) logic — same as documented below:
#   SIGNAL_GATE_ADAPTIVE_REGIME_AWARE=true
# (not SIGNAL_GATE_ADOPTIVE_*; there is no such variable)
#
# Turning the adaptive gate on is recommended for live tuning once you are comfortable, but
# it is not required to “finish” an observation phase — you can keep observing with it off.
SIGNAL_GATE_ADAPTIVE_ENABLED=false
SIGNAL_GATE_ADAPTIVE_CRON_ENABLED=true
SIGNAL_GATE_ADAPTIVE_TICK_MS=1800000
SIGNAL_GATE_ADAPTIVE_LOOKBACK_HOURS=168
SIGNAL_GATE_ADAPTIVE_MAX_ROWS=3000
# Min resolved rows in lookback before tuner applies (below -> insufficient_resolved_sample; not a bug).
SIGNAL_GATE_ADAPTIVE_MIN_RESOLVED=80
# When true, adaptive tuner may tighten from the worst-performing emission_regime bucket
# (min SIGNAL_GATE_ADAPTIVE_MIN_PER_REGIME resolved rows per bucket; excludes legacy).
# Default false — same as today until you enable explicitly.
SIGNAL_GATE_ADAPTIVE_REGIME_AWARE=false
SIGNAL_GATE_ADAPTIVE_MIN_PER_REGIME=20
# Calibrator bot (advisory weights, bounded + safe).
SIGNAL_CALIBRATOR_ENABLED=true
SIGNAL_CALIBRATOR_TICK_MS=21600000
SIGNAL_CALIBRATOR_LOOKBACK_HOURS=72
SIGNAL_CALIBRATOR_MIN_SAMPLES=30
SIGNAL_CALIBRATOR_MAX_DELTA_PCT=0.35
# Phase 5 — signals/latest quality: recency decay, calibrator weights on perf rows, optional anomaly skip.
# Recency: multiplier trends toward SIGNAL_FEED_RECENCY_FLOOR over ~SIGNAL_FEED_RECENCY_TAU_MIN minutes.
SIGNAL_FEED_RECENCY_TAU_MIN=120
SIGNAL_FEED_RECENCY_FLOOR=0.82
# Blend strength for geometric mean of per-tag calibrator weights (0..1).
SIGNAL_FEED_PERF_WEIGHT_BLEND=0.75
# Clamp perfW*recW before applying to sentinel score (safety rails).
SIGNAL_FEED_QUALITY_STACK_MIN=0.72
SIGNAL_FEED_QUALITY_STACK_MAX=1.12
# Exclude feed candidates when abs(result_pct or 1h est.) exceeds this (0 = disabled).
SIGNAL_FEED_EXCLUDE_ABS_OUTCOME_PCT=0
# Skip candidates when Dex-reported liquidity is below this USD (0 = disabled). Requires finite liquidity on the quote.
SIGNAL_FEED_MIN_LIQUIDITY_USD=0
# Optional: skip when Dex pair is younger than N minutes or older than N days (0 = disabled). Needs pairCreatedAt from Dex path.
SIGNAL_FEED_MIN_PAIR_AGE_MINUTES=0
SIGNAL_FEED_MAX_PAIR_AGE_DAYS=0
# Market data circuit breakers (Pillar 2b: graceful degradation).
MARKETDATA_DEX_CB_FAILURES=4
MARKETDATA_DEX_CB_OPEN_MS=45000
MARKETDATA_DEX_CB_HALF_OPEN_CALLS=2
MARKETDATA_DEX_CB_HALF_OPEN_SUCCESS=2
# Optional: dedicated circuit for Dex hot discovery path.
MARKETDATA_DEX_HOT_CB_FAILURES=4
MARKETDATA_DEX_HOT_CB_OPEN_MS=45000
MARKETDATA_DEX_HOT_CB_HALF_OPEN_CALLS=2
MARKETDATA_DEX_HOT_CB_HALF_OPEN_SUCCESS=2
# Optional: Birdeye token provider circuit (secondary provider).
MARKETDATA_BIRDEYE_CB_FAILURES=4
MARKETDATA_BIRDEYE_CB_OPEN_MS=45000
MARKETDATA_BIRDEYE_CB_HALF_OPEN_CALLS=2
MARKETDATA_BIRDEYE_CB_HALF_OPEN_SUCCESS=2
# Retry only on 429 with short jitter.
MARKETDATA_RETRY_429_MAX=2
MARKETDATA_RETRY_429_MIN_MS=200
MARKETDATA_RETRY_429_MAX_MS=600
# In-process dedupe window per mint to reduce burst calls.
MARKETDATA_DEDUP_WINDOW_MS=1500
# Max age for stale-safe DB snapshot fallback (ms).
MARKET_SNAPSHOT_MAX_AGE_MS=300000
# Warmup cron to prefill market snapshots every 20-40s.
MARKET_SNAPSHOT_WARMUP_ENABLED=true
MARKET_SNAPSHOT_WARMUP_TICK_MS=30000
MARKET_SNAPSHOT_WARMUP_MINTS_PER_TICK=24
MARKETDATA_CG_CB_FAILURES=4
MARKETDATA_CG_CB_OPEN_MS=45000
MARKETDATA_CG_CB_HALF_OPEN_CALLS=2
MARKETDATA_CG_CB_HALF_OPEN_SUCCESS=2

# Comma-separated browser origins (REST + Socket.IO). If unset in production, allows sentinel-ledger-ochre.vercel.app and *.vercel.app previews.
ALLOWED_ORIGINS=https://sentinel-ledger-ochre.vercel.app

# If set, Helius webhook must send Authorization: Bearer <secret> OR header x-helius-secret: <secret>
HELIUS_WEBHOOK_SECRET=

# Public app URL for Stripe redirects, Telegram / X deep links
SENTINEL_APP_URL=https://sentinel-ledger-ochre.vercel.app
NEXT_PUBLIC_APP_URL=https://sentinel-ledger-ochre.vercel.app
# Optional legacy alias used by some scripts/routes.
FRONTEND_URL=https://sentinel-ledger-ochre.vercel.app

# X (Twitter) write access — grade alerts + omni broadcast channel "x" post short tweets with links.
# Create app at https://developer.x.com — OAuth 1.0a User context (Read and Write).
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Stripe subscriptions (webhook URL: https://<your-backend>/api/v1/stripe-webhook).
# Enable Stripe Tax in Dashboard (Settings → Tax) so Checkout automatic_tax works.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: previous/rotated endpoint secret (accepted during migration).
STRIPE_WEBHOOK_SECRET_ALT=
# Optional: comma-separated list of webhook secrets (advanced rotation).
STRIPE_WEBHOOK_SECRETS=
# Must match the Signing secret (whsec...) for the same mode (test/live) as STRIPE_SECRET_KEY.
# Webhook URL: https://<backend-host>/api/v1/stripe-webhook
STRIPE_PRO_PRICE_ID=
STRIPE_SUPER_PRO_PRICE_ID=
STRIPE_LIFETIME_PRICE_ID=
