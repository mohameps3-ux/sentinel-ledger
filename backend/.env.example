PORT=3000
NODE_ENV=production
JWT_SECRET=change_me_now_use_a_long_random_string
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
UPSTASH_REDIS_REST_URL=your_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token
# Optional: only needed if you want BullMQ queues locally.
UPSTASH_REDIS_URL=redis://default:password@host:port
HELIUS_KEY=your_helius_api_key
# Optional: Birdeye Data Services — realized PnL per wallet for a given token (GET /wallet/v2/pnl/multiple).
# https://bds.birdeye.so — Lite+ plans include Wallet PnL APIs.
BIRDEYE_API_KEY=
# Set to "true" only to fall back to curated smart_wallets rows in Supabase (demo).
# Default: on-chain only (Helius + RPC).
SMART_MONEY_DB_FALLBACK=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
OMNI_BOT_OPS_KEY=set_a_long_random_ops_key

# Comma-separated browser origins (REST + Socket.IO). If unset in production, allows sentinel-ledger-ochre.vercel.app and *.vercel.app previews.
ALLOWED_ORIGINS=https://sentinel-ledger-ochre.vercel.app

# If set, Helius webhook must send Authorization: Bearer <secret> OR header x-helius-secret: <secret>
HELIUS_WEBHOOK_SECRET=

# Public app URL for Telegram / X deep links (grade alerts, marketing)
SENTINEL_APP_URL=https://sentinel-ledger-ochre.vercel.app

# X (Twitter) write access — grade alerts + omni broadcast channel "x" post short tweets with links.
# Create app at https://developer.x.com — OAuth 1.0a User context (Read and Write).
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

