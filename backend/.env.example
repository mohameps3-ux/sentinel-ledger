PORT=3000
NODE_ENV=production
JWT_SECRET=change_me_now_use_a_long_random_string
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Direct Postgres URI (Supabase → Project Settings → Database → URI, session or transaction mode). Required for `npm run db:ensure-subscriptions` (applies `../supabase/payments_and_pro.sql`).
# DATABASE_URL=
UPSTASH_REDIS_REST_URL=your_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_redis_rest_token
# Optional: only needed if you want BullMQ queues locally.
UPSTASH_REDIS_URL=redis://default:password@host:port
# Optional alias for BullMQ connection string (if you prefer REDIS_URL naming).
REDIS_URL=
# Optional: set to "false" to pause deployer/smart-wallet workers without code changes.
SMART_WORKERS_ENABLED=true
# Optional: when BullMQ is unavailable (no REDIS_URL), analyze up to N wallets directly per cron run.
SMART_WALLET_DIRECT_LIMIT=20
HELIUS_KEY=your_helius_api_key
# Optional: Birdeye Data Services — realized PnL per wallet for a given token (GET /wallet/v2/pnl/multiple).
# https://bds.birdeye.so — Lite+ plans include Wallet PnL APIs.
BIRDEYE_API_KEY=
# Set to "true" only to fall back to curated smart_wallets rows in Supabase (demo).
# Default: on-chain only (Helius + RPC).
SMART_MONEY_DB_FALLBACK=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# PRO watchlist alerts (Telegram). Set false to disable periodic checks.
PRO_ALERTS_CRON_ENABLED=true
# Optional: how often to scan watchlists (ms), min 60000.
PRO_ALERTS_TICK_MS=600000
# Optional: cache TTL (seconds) for smart-money summary merged into PRO Telegram alerts.
PRO_ALERT_SMART_HINT_TTL_SEC=900
# Optional: min top confidence (0–100) to mention smart money when wallet count is low.
PRO_ALERT_SMART_HINT_MIN_CONF=38
# Comma-separated Solana addresses to skip in wallet analysis worker (vaults, infra).
SMART_WALLET_SKIP_ANALYSIS=
# Optional: enable Telegram command polling (/scan, /watchlist). Keep false in production workers to avoid 409 conflicts.
TELEGRAM_POLLING_ENABLED=false
OMNI_BOT_OPS_KEY=set_a_long_random_ops_key

# Comma-separated browser origins (REST + Socket.IO). If unset in production, allows sentinel-ledger-ochre.vercel.app and *.vercel.app previews.
ALLOWED_ORIGINS=https://sentinel-ledger-ochre.vercel.app

# If set, Helius webhook must send Authorization: Bearer <secret> OR header x-helius-secret: <secret>
HELIUS_WEBHOOK_SECRET=

# Public app URL for Stripe redirects, Telegram / X deep links
SENTINEL_APP_URL=https://sentinel-ledger-ochre.vercel.app
NEXT_PUBLIC_APP_URL=https://sentinel-ledger-ochre.vercel.app
# Optional legacy alias used by some scripts/routes.
FRONTEND_URL=https://sentinel-ledger-ochre.vercel.app

# X (Twitter) write access — grade alerts + omni broadcast channel "x" post short tweets with links.
# Create app at https://developer.x.com — OAuth 1.0a User context (Read and Write).
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Stripe subscriptions (webhook URL: https://<your-backend>/api/v1/stripe-webhook).
# Enable Stripe Tax in Dashboard (Settings → Tax) so Checkout automatic_tax works.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: previous/rotated endpoint secret (accepted during migration).
STRIPE_WEBHOOK_SECRET_ALT=
# Optional: comma-separated list of webhook secrets (advanced rotation).
STRIPE_WEBHOOK_SECRETS=
# Must match the Signing secret (whsec...) for the same mode (test/live) as STRIPE_SECRET_KEY.
# Webhook URL: https://<backend-host>/api/v1/stripe-webhook
STRIPE_PRO_PRICE_ID=
STRIPE_SUPER_PRO_PRICE_ID=
STRIPE_LIFETIME_PRICE_ID=
